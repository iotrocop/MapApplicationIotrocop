[Unit]
Description=IOT Scooter Map Application
After=network.target map_backend.service
Wants=map_backend.service

[Service]
Type=simple
User=iot
Group=iot
WorkingDirectory=/home/iot/map_app_src

# Environment configuration
Environment="PATH=/home/iot/.local/bin:/usr/local/bin:/usr/bin:/bin"
Environment="DISPLAY=:0"
Environment="XDG_RUNTIME_DIR=/run/user/1000"
Environment="FLUTTER_CACHE_DIR=/home/iot/.cache/flutter"
Environment="FLUTTER_DISABLE_CRASH_REPORTING=true"

# Give backend time to start
ExecStartPre=/bin/sleep 2

# Start the Linux Flutter executable directly
ExecStart=/home/iot/map_app_src/build/linux/arm64/release/bundle/map_application

# Restart policy
Restart=on-failure
RestartSec=10
StartLimitInterval=120
StartLimitBurst=3

# Timeout settings
TimeoutStartSec=60
TimeoutStopSec=15

[Install]
WantedBy=multi-user.target
